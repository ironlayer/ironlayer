# .envrc — auto-loaded by direnv
# Loads Iron Tools environment for this repo

# Load shared env if available
[ -f ~/.iron/env.local ] && source_env ~/.iron/env.local

# Activate Python venv if present
if [ -d .venv ]; then
  source .venv/bin/activate
fi

# Set workspace root
export WORKSPACE_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)/iron-dev-workspace"
