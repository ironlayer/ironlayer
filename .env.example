# =============================================================================
# IronLayer Root — Docker Compose Environment Overrides
# =============================================================================
#
# Copy to .env. Values here are used by docker-compose.yml.
#
#   cp .env.example .env
#
# =============================================================================

# --- PostgreSQL --------------------------------------------------------------
POSTGRES_USER=ironlayer
POSTGRES_PASSWORD=ironlayer_dev
POSTGRES_DB=ironlayer

# --- API Service -------------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://ironlayer:ironlayer_dev@postgres:5432/ironlayer
AI_ENGINE_URL=http://ai_service:8001
PLATFORM_ENV=dev

# Auth mode: dev | JWT | KMS | OIDC
AUTH_MODE=dev

# JWT signing secret (change in production).
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change-me-in-production
# Set JWT_SECRET_PREVIOUS to the old secret during key rotation windows.
# JWT_SECRET_PREVIOUS=

# Encryption key for stored credentials (separate from JWT_SECRET).
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
CREDENTIAL_KEY=change-me-in-production

# --- Redis (optional) -------------------------------------------------------
# Enables distributed rate limiting + shared token revocation cache.
# When unset, rate limiting is in-process per replica and token revocation
# uses only the L1 in-process cache + L3 DB fallback.
# REDIS_URL=redis://localhost:6379

# --- AI Engine ---------------------------------------------------------------
LLM_ENABLED=false
# LLM_API_KEY=sk-ant-...

# Shared secret for API <-> AI engine authentication (must match on both services).
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
AI_ENGINE_SHARED_SECRET=change-me-in-production

# Comma-separated list of origins allowed by the AI engine CORS middleware.
AI_ENGINE_ALLOWED_ORIGINS=http://localhost:8000

# --- Frontend ----------------------------------------------------------------
VITE_API_URL=http://localhost:8000
# Error reporting endpoint (e.g. Sentry relay, Datadog, or custom collector).
# When unset, frontend errors are logged to the browser console only.
# VITE_ERROR_REPORTING_URL=https://errors.ironlayer.app/collect

# --- Observability (OpenTelemetry) -------------------------------------------
# Set to your OTLP/HTTP collector endpoint to enable distributed tracing.
# When unset, OpenTelemetry is disabled and imposes zero overhead.
# Example (Jaeger / Grafana Tempo / OpenTelemetry Collector):
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
